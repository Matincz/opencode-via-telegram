# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# Required: your Telegram numeric user ID.
# Use ALL only for temporary local debugging.
ALLOWED_USER_ID="YOUR_TELEGRAM_USER_ID_HERE"

# Optional fallback when Desktop/Web backend auto-discovery is unavailable.
OPENCODE_SERVER_URL="http://127.0.0.1:4096"

# Optional basic auth for protected fallback servers.
OPENCODE_SERVER_USERNAME="opencode"
OPENCODE_SERVER_PASSWORD=""

# Optional runtime tuning.
OPENCODE_REQUEST_TIMEOUT_MS="8000"
OPENCODE_RESPONSE_POLL_INTERVAL_MS="1000"
OPENCODE_RESPONSE_POLL_TIMEOUT_MS="180000"
OPENCODE_RESPONSE_POLL_MESSAGE_LIMIT="20"
OPENCODE_BACKEND_CACHE_TTL_MS="5000"
TELEGRAM_POLLING_WATCHDOG_INTERVAL_MS="15000"
TELEGRAM_PENDING_UPDATE_STALL_MS="30000"
LOG_LEVEL="info"
