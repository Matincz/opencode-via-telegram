TELEGRAM_BOT_TOKEN="123456:your-bot-token"
ALLOWED_USER_ID="123456789"
GEMINI_BIN="/opt/homebrew/bin/gemini"
GEMINI_DEFAULT_MODEL="auto-gemini-3"
GEMINI_ALLOWED_MODELS="gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite"
PLAN_MODEL="auto-gemini-3"
EXECUTION_MODEL="auto-gemini-3"
GEMINI_EXECUTION_APPROVAL_MODE="yolo"
GEMINI_RETRY_FETCH_ERRORS="true"
GEMINI_MAX_ATTEMPTS="2"
GEMINI_INCLUDE_DIRECTORIES=""
TG_TOOL_APPROVAL_STRATEGY="plan_then_execute"
GEMINI_SANDBOX="false"
LOG_LEVEL="info"
